#!/bin/bash

set -euo pipefail

# Given either a worker number, or a the end name, resolve the entire hostname

function error() {
  echo -e "$1" > /dev/stderr
  exit 1
}

function usage() {
  error "Usage: anthost [-hn] <host-or-num>
  host-or-num:    antworkerXYZ.hosts.typesofants.org, antworkerXYZ, XYZ

  -h: Display this help text.
  -n: Display only the trailing number, e.g. 999.
"
}


function parse_full() {
  local host="$1"
  if [[ -z "$host" ]]; then
    error "[ERROR] Need hostname argument! For example:
      - antworkerXYZ.hosts.typesofants.org
      - antworkerXYZ
      - XYZ"
  elif [[ ${#host} -gt 12 ]]; then
    # Then this format is "antworkerxyz.hosts.typesofants.org"
    host="$host"
  elif [[ ${#host} -gt 3 ]]; then
    # Then this format is "antworkerxyz"
    host="$host.hosts.typesofants.org"
  else
    # Then this format is "xyz"
    host="antworker${host}.hosts.typesofants.org"
  fi

  echo "$host"
}

while getopts ":h" option; do
   case $option in
      h) usage ;;
      \?) usage;;
   esac
done

parse_full "$@"

exit 0
