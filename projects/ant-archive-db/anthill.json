{
  "project": "ant-archive-db",
  "description": "the typesofants archive metadata store",
  "build": "docker",
  "archetype": {
    "postgres": {
      "database_secret_name": "ant_archive_db_db",
      "username_secret_name": "ant_archive_db_user",
      "password_secret_name": "ant_archive_db_password"
    }
  },
  "ports": {
    "primary": 3257
  },
  "secrets": [
    "ant_archive_db_db",
    "ant_archive_db_user",
    "ant_archive_db_password",
    "ant_db_monitoring_password"
  ]
}