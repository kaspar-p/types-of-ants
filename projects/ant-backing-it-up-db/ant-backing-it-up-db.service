[Unit]
Description=A database for knowing about backups!

[Service]
Type=simple
ExecStart=/snap/bin/docker-compose --project-directory={{INSTALL_DIR}} up --no-build --force-recreate ant-backing-it-up-db
EnvironmentFile={{INSTALL_DIR}}/.env
WorkingDirectory={{INSTALL_DIR}}
Slice=typesofants.slice
Restart=always

[Install]
WantedBy=multi-user.target
